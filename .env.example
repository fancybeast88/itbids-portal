# Database (auto-set by Railway — do not change if on Railway)
DATABASE_URL="postgresql://user:password@localhost:5432/itbids"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_CHAR_STRING"

# Email (Resend)
RESEND_API_KEY="re_REPLACE_WITH_YOUR_KEY"
FROM_EMAIL="noreply@yourdomain.pk"
ADMIN_EMAIL="admin@yourdomain.pk"

# JazzCash
JAZZCASH_MERCHANT_ID="REPLACE"
JAZZCASH_PASSWORD="REPLACE"
JAZZCASH_INTEGRITY_SALT="REPLACE"
JAZZCASH_API_URL="https://payments.jazzcash.com.pk/ApplicationAPI/API/2.0/Purchase/DoMWalletTransaction"

# Easypaisa
EASYPAISA_STORE_ID="REPLACE"
EASYPAISA_ACCOUNT_NUMBER="REPLACE"
EASYPAISA_API_KEY="REPLACE"

# Cloudflare R2 / AWS S3 file storage
R2_ACCOUNT_ID="REPLACE"
R2_ACCESS_KEY="REPLACE"
R2_SECRET_KEY="REPLACE"
R2_BUCKET_NAME="itbids-uploads"
