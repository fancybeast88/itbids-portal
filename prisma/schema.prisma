generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  approvedAt   DateTime?
  approvedById String?
  approvedBy   User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvals    User[]   @relation("ApprovedBy")
  vendorProfile   VendorProfile?
  businessProfile BusinessProfile?
  notifications   Notification[]
}

model VendorProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  contactPerson String
  phone         String?
  city          String?
  ntn           String?
  partnerLevel  String?
  brands        String[]
  credits       Int      @default(0)
  createdAt     DateTime @default(now())
  rfqUnlocks         RfqUnlock[]
  quotes             Quote[]
  creditTransactions CreditTransaction[]
}

model BusinessProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  contactPerson String
  phone         String?
  city          String?
  ntn           String?
  credits       Int      @default(0)
  createdAt     DateTime @default(now())
  rfqs Rfq[]
}

model Rfq {
  id           String   @id @default(uuid())
  businessId   String
  business     BusinessProfile @relation(fields: [businessId], references: [id])
  title        String
  brand        String
  category     String
  quantity     String?
  budgetPkr    BigInt?
  city         String?
  specs        String?
  creditCost   Int      @default(2)
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  approvedAt   DateTime?
  approvedById String?
  expiresAt    DateTime?
  unlocks RfqUnlock[]
  quotes  Quote[]
}

model RfqUnlock {
  id          String        @id @default(uuid())
  rfqId       String
  rfq         Rfq           @relation(fields: [rfqId], references: [id])
  vendorId    String
  vendor      VendorProfile @relation(fields: [vendorId], references: [id])
  creditsUsed Int
  unlockedAt  DateTime      @default(now())
  @@unique([rfqId, vendorId])
}

model Quote {
  id           String        @id @default(uuid())
  rfqId        String
  rfq          Rfq           @relation(fields: [rfqId], references: [id])
  vendorId     String
  vendor       VendorProfile @relation(fields: [vendorId], references: [id])
  totalAmount  BigInt
  lineItems    Json
  deliveryDays String?
  warranty     String?
  paymentTerms String?
  notes        String?
  proformaUrl  String?
  validityDays Int           @default(14)
  status       String        @default("submitted")
  submittedAt  DateTime      @default(now())
}

model CreditTransaction {
  id            String        @id @default(uuid())
  vendorId      String
  vendor        VendorProfile @relation(fields: [vendorId], references: [id])
  type          String
  credits       Int
  amountPkr     Int?
  paymentMethod String?
  paymentRef    String?
  status        String        @default("pending")
  createdAt     DateTime      @default(now())
  confirmedAt   DateTime?
}

model CategoryCreditCost {
  id        String   @id @default(uuid())
  category  String   @unique
  cost      Int      @default(2)
  updatedAt DateTime @default(now())
}

model CreditPackage {
  id        String   @id @default(uuid())
  credits   Int
  pricePkr  Int
  label     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String?
  body      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailSettings {
  id    String  @id @default(uuid())
  key   String  @unique
  value Boolean @default(true)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model BusinessCreditTransaction {
  id        String          @id @default(uuid())
  bizId     String
  business  BusinessProfile @relation(fields: [bizId], references: [id])
  type      String
  credits   Int
  rfqId     String?
  status    String          @default("confirmed")
  createdAt DateTime        @default(now())
}
